# Manager environment
# Copy to .env and edit. start.sh will warn if API_ID/API_HASH are empty.

# Flask
PORT=5000
# Optional: protect /api/ingest with a token (leave blank to disable)
INGEST_TOKEN=
# Optional: public URL where the app is reachable (used to display miniapp URL).
# If you use USE_TUNNEL=1 in start.sh, this is set automatically.
MINI_APP_URL=

# Telegram (used for BOTH the bot polling AND live session management)
API_ID=
API_HASH=
BOT_TOKEN=
LOG_CHANNEL_ID=
